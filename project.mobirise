          "_name": "content10",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content10\" group=\"Content\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"checkbox\" name=\"reverseContent\" title=\"Reverse\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"10\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"8\" value=\"4\" step=\"1\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#2c2c2c\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md\">\n                <h5 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\">\n                    <b>Kontakt</b>\n                </h5>\n                <h6 class=\"mbr-section-subtitle mbr-fonts-style mb-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\">Für Rückfragen, weitere Unterlagen oder ein vertiefendes Gespräch stehe ich Ihnen gerne zur Verfügung. Eine Kontaktaufnahme per E‑Mail ist jederzeit möglich.\n<div>\n</div><div><br></div></h6>\n            </div>\n            <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\"><b><br></b><br><b>&nbsp; &nbsp; &nbsp; &nbsp;Kontaktdaten:</b><br><span style=\"display:inline-block;width:0.45em;height:0.45em;border-radius:50%;background:#ff6b00;margin-right:1em;vertical-align:middle;\"></span>E-Mail:&nbsp; &nbsp; &nbsp; *********<a href=\"mailto:SVETLANA@gmail.com\" class=\"text-secondary\">A@gmail.com</a><br><span style=\"display:inline-block;width:0.45em;height:0.45em;border-radius:50%;background:#ff6b00;margin-right:1em;vertical-align:middle;\"></span>Telefon:&nbsp; &nbsp; <a href=\"tel:+491703128604\" class=\"text-secondary text-primary\">+49 *</a>*************<br><span style=\"display:inline-block;width:0.45em;height:0.45em;border-radius:50%;background:#4da2db;margin-right:1em;vertical-align:middle;\"></span>Standort:&nbsp; 06108 Halle (Saale), Deutschland<br></p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "v5nqV9HXlA",
